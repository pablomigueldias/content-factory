APP_NAME="Content Factory"
ENVIRONMENT=development
DATABASE_URL="postgresql+psycopg://factory:factory@localhost:5435/content_factory"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# ---------- Voz (Chatterbox) ----------
TTS_LANGUAGE="pt"
# WAV de referência com o tom do Bolonhesa (clonagem de voz). Vazio = voz default.
TTS_VOICE_REFERENCE=""
# Entonação debochada: menor CFG_WEIGHT = fala mais lenta/arrastada.
TTS_EXAGGERATION=0.5
TTS_CFG_WEIGHT=0.5
TTS_TEMPERATURE=0.8